# ------------------------------------------------------------------------------
# DAC Platform - Central API Environment Configuration
# ------------------------------------------------------------------------------

# Controls whether the API uses the Local Filesystem (development)
# or connects to AWS S3 & Postgres (production).
#
# Valid Modes:
#   development  -> API scans your local /sample-docs directory
#   production   -> API polls postgres DB and downloads content from S3
NODE_ENV=development

# Controls whether local development API serves raw Markdown (.md)
# or dynamically compiles and serves HTML (.html) to mimic Production SSG.
SERVE_PREBUILT_HTML=true

# AWS Storage Configuration (Required for Production Mode)
AWS_S3_DOCUMENT_BUCKET=dac-enterprise-docs
AWS_REGION=us-east-1

# Publishing API Authentication 
DAC_PUBLISH_API=http://localhost:3000/api/publish
